{
  "name": "@aes/artifact-registry",
  "version": "0.1.0",
  "description": "AES Platform — Append-only artifact registry",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aes-platform": "dist/cli/aes-platform.js"
  },
  "private": true,
  "scripts": {
    "build": "tsc",
    "builder:run": "node scripts/run-live-mode.mjs run-builder",
    "health:live": "node scripts/run-live-mode.mjs health",
    "stack:down": "node scripts/local-stack.mjs down",
    "stack:status": "node scripts/local-stack.mjs status",
    "stack:up": "node scripts/local-stack.mjs up",
    "start:real": "node scripts/run-live-mode.mjs serve",
    "start:operator": "node dist/cli/aes-platform.js serve",
    "health": "node dist/cli/aes-platform.js health",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.5.2"
  },
  "optionalDependencies": {
    "@types/pg": "^8.11.6",
    "pg": "^8.12.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "neo4j-driver": "^6.0.1"
  }
}
